{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"]
  },
  "overrides": [
    {
      "files": ["public/js/**/*.js", "js/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "globals": {
        "App": "readonly",
        "Store": "readonly",
        "Pages": "readonly",
        "Components": "readonly",
        "CITIES": "readonly",
        "SPECIALTIES": "readonly",
        "TIME_SLOTS": "readonly",
        "seedDatabase": "readonly"
      }
    }
  ]
}
