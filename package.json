{
  "name": "medicap",
  "version": "3.1.0",
  "description": "MediCap - Doctor & Patient Management System for Gujarat and India with Google Cloud integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "start-server-and-test start http://localhost:8080 \"node tests/api.test.js && jest tests/server.test.js\"",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.+(js|json|html|css)\"",
    "test:health": "node -e \"fetch('http://localhost:8080/api/health').then(r=>r.json()).then(console.log)\""
  },
  "keywords": [
    "healthcare",
    "doctor",
    "patient",
    "appointments",
    "medical-records",
    "gujarat",
    "india",
    "google-cloud",
    "cloud-run"
  ],
  "author": "MediCap Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google-cloud/error-reporting": "^3.0.0",
    "@google-cloud/logging": "^11.0.0",
    "@google-cloud/pubsub": "^4.3.3",
    "@google-cloud/storage": "^7.9.0",
    "@google/generative-ai": "^0.2.1",
    "apicache": "^1.6.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "googleapis": "^133.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "redis": "^4.6.10",
    "uuid": "^9.0.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/apicache": "^1.6.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "cypress": "^13.6.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "start-server-and-test": "^3.0.0",
    "supertest": "^6.3.3"
  }
}
